# =============================================================================
# New-API 环境变量配置
#
# 复制本文件为 .env，填写真实值后使用
#   cp .env.example .env
#
# .env 已在 .gitignore 中，不会被提交
# =============================================================================

# ================================
# 生产机部署（scripts/3-deploy-ha.sh）
# ================================
# Production 机器 IP
PROD_IP=192.168.6.114
# 内网 Docker Registry 地址
REGISTRY=192.168.6.247:5000
# SSH 登录用户名
SSH_USER=zhuxi
# SSH 私钥路径
SSH_KEY_PATH=/home/zhuxi/.ssh/id_ed25519
# 生产机上的项目路径
REMOTE_DIR=~/allinone/new-api

# ================================
# 生产 DB / Redis（scripts/prod/docker-compose.yml）
# ================================
# SESSION_SECRET — 用于加密 session，任意长字符串
SESSION_SECRET=change-me-to-a-random-string

# PostgreSQL
SQL_USER=newapi
SQL_PASSWORD=change-me-to-postgres-password
SQL_DB=new-api
SQL_HOST=postgres
SQL_PORT=5432

# Redis
REDIS_PASSWORD=change-me-to-redis-password
REDIS_HOST=redis
REDIS_PORT=6379

# ================================
# 本地测试令牌（scripts/concurrency.go / init_test_db.go）
# ================================
# 并发测试使用的本地 token key（不含 sk- 前缀）
TEST_TOKEN_KEY=concur00key00xxyyzz0011223344556677aabbccdd
# Dummy channel 使用的 key
DUMMY_KEY=dummy-key-for-test

# 本地服务地址
LOCAL_URL=http://localhost:3000

# 测试模型名
TEST_MODEL=test-gpt-concurrency
